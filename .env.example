# Copy this file to .env and fill in the values from your Oura app registration
# at https://cloud.ouraring.com/oauth/applications

OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Must exactly match a redirect URI registered on your Oura app.
# The defaults below only need changing if you register a different port/path.
OURA_REDIRECT_URI=http://localhost:8734/callback
OURA_AUTH_PORT=8734

# Where tokens.json gets written/read. Default is fine for almost everyone.
# OURA_TOKEN_PATH=/home/you/.oura-mcp/tokens.json
